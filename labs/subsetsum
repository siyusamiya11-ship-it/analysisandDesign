#include <iostream>
#include <vector>
using namespace std;

void subsetSum(vector<int>& arr, vector<int>& current, int index, int target) {
    // If target achieved
    if (target == 0) {
        cout << "{ ";
        for (int x : current) cout << x << " ";
        cout << "}" << endl;
        return;
    }

    // If out of bounds or target becomes negative
    if (index >= arr.size() || target < 0)
        return;

    // Include current element
    current.push_back(arr[index]);
    subsetSum(arr, current, index + 1, target - arr[index]);

    // Exclude current element (backtrack)
    current.pop_back();
    subsetSum(arr, current, index + 1, target);
}

int main() {
    vector<int> arr = {1, 2, 3, 4};
    int target = 5;
    vector<int> current;

    subsetSum(arr, current, 0, target);

    return 0;
}
