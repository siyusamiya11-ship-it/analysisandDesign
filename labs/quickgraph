import matplotlib.pyplot as plt

steps = []

def quick_sort(arr, low, high):
    if low < high:
        pi = partition(arr, low, high)
        steps.append(arr.copy())   # store state after partition
        quick_sort(arr, low, pi - 1)
        quick_sort(arr, pi + 1, high)

def partition(arr, low, high):
    pivot = arr[high]
    i = low - 1

    for j in range(low, high):
        if arr[j] < pivot:
            i += 1
            arr[i], arr[j] = arr[j], arr[i]

    arr[i + 1], arr[high] = arr[high], arr[i + 1]
    return i + 1


def plot_steps(steps):
    passes = list(range(len(steps)))

    for i in range(len(steps[0])):
        plt.plot(passes, [step[i] for step in steps], marker='o')

    plt.xlabel("Steps (Partitions)")
    plt.ylabel("Element Values")
    plt.title("Quick Sort Visualization")
    plt.grid()
    plt.show()


# Example
arr = [5, 2, 9, 1, 6]
steps.append(arr.copy())

quick_sort(arr, 0, len(arr) - 1)
plot_steps(steps)
